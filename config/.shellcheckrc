# ShellCheck configuration for MIO-KITCHEN-ANDROID
# Stage 16: shell static analysis baseline
# Docs: https://github.com/koalaman/shellcheck/wiki/Directive

# RU: Пути к shell-скриптам, которые проверяет shellcheck.
#     На данный момент это скрипты KrScript и pio.
# EN: Paths to shell scripts that shellcheck will lint.
#     Currently KrScript and pio scripts.

# Disable SC2086 (double-quote to prevent globbing) — firmware scripts
# intentionally rely on word-splitting for $VAR expansion in many places.
disable=SC2086

# Disable SC2155 (declare and assign separately) — common in legacy scripts.
disable=SC2155

# Disable SC2034 (unused variable) — many shell vars are exported and used
# by sub-scripts.
disable=SC2034

# Disable SC1090 (sourcing non-constant file) — executor.sh sources
# runtime-generated files by design.
disable=SC1090
disable=SC1091

# Disable SC2128 (expanding array without index) — legacy pattern.
disable=SC2128

# Disable SC2207 (read array from command) — legacy pattern.
disable=SC2207

# Treat these as external-sourced (skip "command not found" for app-bundled
# binaries like busybox, magiskboot, lpunpack).
external-sources="true"

# RU: Включить дополнительные предупреждения для неподвижных скриптов.
# EN: Enable additional warnings for non-portable scripts.
enable=require-variable-braces
enable=deprecate-which
