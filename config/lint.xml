<?xml version="1.0" encoding="UTF-8"?>
<!--
    RU: Базовая конфигурация Android Lint для MIO-KITCHEN-ANDROID.
        Stage 16: статический analysis baseline.

        ВНИМАНИЕ: lint{ abortOnError = false } оставлен в pio/build.gradle,
        потому что в проекте ещё много legacy-кода. Этот lint.xml снижает
        шум от известных категорий, не отключая lint полностью.

    EN: Baseline Android Lint configuration for MIO-KITCHEN-ANDROID.
        Stage 16: static analysis baseline.

        NOTE: lint{ abortOnError = false } is still set in pio/build.gradle
        because the project still has a lot of legacy code. This lint.xml
        quiets known noisy categories without disabling lint entirely.
-->
<lint>

    <!-- Severity overrides: elevate issues we care about. -->
    <issue id="HardcodedText" severity="warning" />
    <issue id="MissingTranslation" severity="warning" />
    <issue id="ExtraTranslation" severity="error" />

    <!-- Disable issues that conflict with our architecture. -->

    <!-- RU: ScopedStorage предупреждения отключены — мы используем
         StorageGateway + FirmwareWorkspace (Stage 4) и targetSdk 35 (Stage 13). -->
    <issue id="ScopedStorage" severity="none" />

    <!-- RU: OldTargetApi отключен — targetSdk поднят до 35 в Stage 13,
         но minSdk остаётся 21, что вызывает ложные срабатывания. -->
    <issue id="OldTargetApi" severity="none" />

    <!-- RU: TrustAllX509TrustManager отключен — приложение работает с
         локальными файлами прошивок и не делает сетевых запросов с
         пользовательскими сертификатами. -->
    <issue id="TrustAllX509TrustManager" severity="none" />

    <!-- RU: AllowBackup отключен в пользу явного android:allowBackup="true"
         в манифесте. -->
    <issue id="AllowBackup" severity="none" />

    <!-- RU: ExportedContentProvider не отключаем, но снижаем severity. -->
    <issue id="ExportedContentProvider" severity="warning" />

    <!-- RU: Использование ContentProvider для file sharing — известный
         паттерн для file manager. -->
    <issue id="GrantAllUris" severity="warning" />

    <!-- RU: Использование System.exit в shell runtime — ожидаемо. -->
    <issue id="RuntimeExit" severity="none" />

    <!-- RU: Использование StaticFieldLeak в KeepShellPublic — осознанное
         решение для долгоживущего shell процесса. -->
    <issue id="StaticFieldLeak" severity="warning" />

    <!-- RU: UnusedResources — слишком много false positives из-за
         условных сборок. -->
    <issue id="UnusedResources" severity="warning" />

    <!-- RU: Typos — не блокирует. -->
    <issue id="Typos" severity="warning" />

    <!-- RU: IconLauncherShape — не блокирует. -->
    <issue id="IconLauncherShape" severity="none" />

    <!-- RU: UseAppTint — не блокирует. -->
    <issue id="UseAppTint" severity="none" />

</lint>
