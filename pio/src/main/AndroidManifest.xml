<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        RU: Legacy storage permissions ограничены maxSdkVersion=32 — на Android 13+
            они не выдаются системой, но нужны для запуска на Android ≤ 12.
            На Android 13+ приложение использует SAF (StorageGateway + FirmwareWorkspace)
            и не требует READ_EXTERNAL_STORAGE.
        EN: Legacy storage permissions are capped at maxSdkVersion=32 — on Android 13+
            they are not granted by the system, but are needed to run on Android ≤ 12.
            On Android 13+ the app uses SAF (StorageGateway + FirmwareWorkspace)
            and does not require READ_EXTERNAL_STORAGE.
    -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.VIBRATE" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="com.android.launcher.permission.INSTALL_SHORTCUT" />
    <uses-permission android:name="com.android.launcher.permission.UNINSTALL_SHORTCUT" />

    <!--
        RU: На Android 13+ (API 33+) для POST_NOTIFICATIONS требуется runtime-permission.
        EN: On Android 13+ (API 33+) POST_NOTIFICATIONS requires a runtime permission.
    -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
        RU: На Android 14+ (API 34+) для foreground-сервисов нужно указать тип.
            MIO-KITCHEN использует foreground service для длительных firmware-операций.
        EN: On Android 14+ (API 34+) foreground services must declare a type.
            MIO-KITCHEN uses a foreground service for long-running firmware operations.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <application
        android:name=".PIO"
        android:allowBackup="true"
        android:usesCleartextTraffic="true"
        android:icon="@mipmap/logo"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/AppTheme"
        android:requestLegacyExternalStorage="false"
        tools:ignore="GoogleAppIndexingWarning"
        tools:targetApi="m">

        <meta-data
            android:name="android.max_aspect"
            android:value="2.8" />

        <activity
            android:name=".ActionPage"
            android:label="@string/title_activity_action_page"
            android:configChanges="keyboardHidden|orientation|uiMode|layoutDirection|screenLayout|colorMode|fontScale|smallestScreenSize|density|keyboard|screenSize|touchscreen"
            android:screenOrientation="portrait"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
        <activity
            android:name=".MainActivity"
            android:configChanges="keyboardHidden|orientation|uiMode|layoutDirection|screenLayout|colorMode|fontScale|smallestScreenSize|density|keyboard|screenSize|touchscreen"
            android:screenOrientation="portrait"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
        <activity
            android:name=".SplashActivity"
            android:configChanges="keyboardHidden|orientation|uiMode|layoutDirection|screenLayout|colorMode|fontScale|smallestScreenSize|density|keyboard|screenSize|touchscreen"
            android:screenOrientation="portrait"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".ActivityFileSelector"
            android:excludeFromRecents="true"
            android:label="@string/title_activity_file_selector"
            android:configChanges="keyboardHidden|orientation|uiMode|layoutDirection|screenLayout|colorMode|fontScale|smallestScreenSize|density|keyboard|screenSize|touchscreen"
            android:launchMode="standard"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>
        <!--
            RU: Новый экран анализа прошивки (Stage 15). Использует AppRuntimeProfile
                + FirmwareAnalysisViewModel + RuntimePermissionHelper +
                OpenDocumentHelper + FirmwareOperationService.
            EN: New firmware analysis screen (Stage 15). Uses AppRuntimeProfile
                + FirmwareAnalysisViewModel + RuntimePermissionHelper +
                OpenDocumentHelper + FirmwareOperationService.
        -->
        <activity
            android:name=".ui.modern.FirmwareAnalysisActivity"
            android:label="@string/app_name"
            android:configChanges="keyboardHidden|orientation|uiMode|layoutDirection|screenLayout|colorMode|fontScale|smallestScreenSize|density|keyboard|screenSize|touchscreen"
            android:screenOrientation="portrait"
            android:exported="false" />
        <provider
            android:name="com.mio.kitchen.MTDataFilesProvider"
            android:exported="false"
            android:authorities="com.mio.kitchen.MTDataFilesProvider"
            android:grantUriPermissions="true">
        </provider>

        <!--
            RU: Foreground service для длительных firmware-операций.
                На Android 14+ тип dataSync обязателен.
            EN: Foreground service for long-running firmware operations.
                On Android 14+ the dataSync type is mandatory.
        -->
        <service
            android:name=".FirmwareOperationService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />
    </application>

</manifest>