<?xml version="1.0" encoding="UTF-8" ?>
<page>
    <group title="@string/script_group_script_executor">
        <action>
            <title>@string/script_group_script_executor</title>
            <summary>@string/script_summary_custom_command</summary>
            <set>$TO</set>
            <param name="TO" placeholder="@string/script_placeholder_custom_command" value="" requiret="true" />
        </action>
    </group>

    <group>
        <action>
            <title>@string/script_action_flash_image</title>
            <set>script/tool.sh flash_img</set>
            <param name="CQ" label="@string/script_label_reboot_after_flash" type="checkbox" />
            <param name="CQ1" label="@string/script_label_reboot_recovery_after_flash" type="checkbox" />
            <param name="IMG" title="@string/script_title_flash_image_size_warning" options-sh="script/tool.sh parts" required="true"/>
            <param name="Brush_in" type="file" suffix="img" editable="true" required="true" title="@string/script_title_input_img_path" desc="@string/script_desc_path_no_spaces"/>
        </action>
        <action>
            <title>@string/script_action_extract_image_file</title>
            <set>script/tool.sh extract_part</set>
            <param name="IMG" title="@string/script_title_select_partition_multi" multiple="true" options-sh="script/tool.sh parts" required="true"/>
        </action>
    </group>

    <group>
        <text>
            <slices>
                <slice size="17" align="center" color="black">@string/script_text_statement_title</slice>
                <slice break="true"/>
                <slice color="red" align="center" size="14">@string/script_text_statement_risk</slice><slice/>
                <slice color="red" align="center" size="14">@string/script_text_statement_bug_feedback</slice><slice break="true"/>
            </slices>
        </text>
    </group>
</page>
