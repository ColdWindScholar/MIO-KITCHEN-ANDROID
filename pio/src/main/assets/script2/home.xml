<?xml version="1.0" encoding="UTF-8" ?>
<resource dir="file:///android_asset/script" />
<items>
    <group title="@string/script_group_overview">
        <action reload="true" auto-off="true">
            <title>@string/script_action_project_list</title>
            <param name="xm" options-sh="script/tool.sh check"/>
            <set>echo "$xm" &gt; ${XBJ}</set>
            <summary sh="script/tool.sh zy" />
        </action>
    </group>

    <group title="@string/script_group_tools">
        <action reload="true" auto-off="true">
            <title>@string/script_action_download_rom</title>
            <param name="jb" label="@string/script_label_unpack_after_download" type="switch" />
            <param name="del" label="@string/script_label_delete_source_after_unpack" type="switch" />
            <param name="romdz" label="@string/script_label_input_link" title="@string/script_title_input_link" placeholder="@string/script_placeholder_input" type="text" />
            <script>script/tool.sh download</script>
        </action>

        <action reload="true" auto-off="true">
            <title>@string/script_action_select_rom</title>
            <set>script/tool.sh UZ</set>
            <param name="del" label="@string/script_label_delete_source" type="switch" />
            <param name="xzrom" label="@string/script_label_file_select" type="file" suffix="zip" />
        </action>

        <action reload="true" auto-off="true">
            <title>@string/script_action_delete_project</title>
            <param multiple="true" name="xms" options-sh="script/tool.sh check"/>
            <set>script/tool.sh del</set>
        </action>

        <action reload="true" auto-off="true">
            <title>@string/script_action_new_project</title>
            <param name="xmmc" label="@string/script_label_project_name" title="@string/script_title_input_project_name" placeholder="@string/script_placeholder_project_name" type="text" />
            <set>script/tool.sh mn</set>
        </action>

        <page title="@string/script_page_project_menu" config="file:///android_asset/script2/mio.xml">
            <set>cd $SH_DIR</set>
            <lock>script/tool.sh unlock</lock>
        </page>
    </group>
</items>
