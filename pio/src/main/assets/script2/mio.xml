<?xml version="1.0" encoding="UTF-8" ?>
<resource dir="file:///android_asset/script" />
<group title="@string/script_group_module_features">
    <page reload="true" config-sh="script/tool.sh module" title="@string/script_page_modules" desc="@string/script_page_modules_desc"/>
</group>

<group title="@string/script_group_extract_menu">
    <action>
        <title>@string/script_action_extract_rom</title>
        <set>script/tool.sh UN</set>
    </action>
    <action>
        <title>@string/script_action_unpack_br</title>
        <set>script/tool.sh zdyfj</set>
        <param name="cleanup" label="@string/script_label_delete_source" type="checkbox" />
        <param name="zdy" title="@string/script_title_select_files_multi" options-sh="script/tool.sh new.dat.br" desc="@string/script_desc_auto_detect" required="true" multiple="true"/>
    </action>

    <action>
        <title>@string/script_action_unpack_dat</title>
        <set>script/tool.sh zdyfj</set>
        <param name="cleanup" label="@string/script_label_delete_source" type="checkbox" />
        <param name="zdy" title="@string/script_title_select_dat_multi" options-sh="script/tool.sh new.dat" desc="@string/script_desc_detect_project_files" required="true" multiple="true"/>
    </action>

    <action>
        <title>@string/script_action_extract_super_payload</title>
        <set>script/tool.sh tqdgjx</set>
        <param name="qptq" label="@string/script_label_extract_all" type="switch" />
        <param name="del" label="@string/script_label_delete_source" type="switch" />
        <param name="tqjx" title="@string/script_title_select_extract_image" options-sh="script/tool.sh dg" desc="@string/script_desc_auto_detect" required="true" multiple="true"/>
        <param name="jxs" title="@string/script_title_select_partitions" options-sh="script/tool.sh readdt" desc="@string/script_desc_auto_detect" required="true" multiple="true"/>
    </action>

    <action>
        <title>@string/script_action_unpack_img</title>
        <set>script/tool.sh zdyfj</set>
        <param name="cleanup" label="@string/script_label_delete_source" type="checkbox" />
        <param name="IMG" title="@string/script_title_select_files_multi" options-sh="script/tool.sh img" desc="@string/script_desc_detect_img_project_files" required="true" multiple="true"/>
    </action>
</group>

<group title="@string/script_group_pack_menu">
    <action>
        <title>@string/script_action_pack_image</title>
        <set>script/tool.sh pack</set>
        <param name="UIMGS" options-sh="script/tool.sh lsmdir" desc="@string/script_desc_multi_pack_auto_detect" required="true" multiple="true"/>
        <param name="dbfs" label="@string/script_label_pack_method" desc="@string/script_desc_ext4_only">
            <option value="mkeimg">mke2fs+e2fsdroid</option>
            <option value="make_ext4">make_ext4fs</option>
        </param>
        <param name="jxys" label="@string/script_label_image_compression" type="switch" />
        <param name="del" label="@string/script_label_delete_source" type="switch" />
        <param name="zhua" label="@string/script_label_erofs_ext_convert_pack" type="switch" />
        <param name="fixb" label="@string/script_label_fix_build" desc="@string/script_desc_ext4_only" type="switch" />
        <param name="Reading" label="@string/script_label_partition_read_write" desc="@string/script_desc_ext4_only">
            <option value="ro">@string/script_option_read_only</option>
            <option value="rw">@string/script_option_read_write</option>
        </param>
        <param name="psize" label="@string/script_label_pack_size" desc="@string/script_desc_ext4_only">
            <option value="auto">@string/script_option_auto_size</option>
            <option value="orig">@string/script_option_original_img_size</option>
        </param>
        <param name="img_type" label="@string/script_label_pack_format" desc="@string/script_desc_ext4_only">
            <option value="raw">raw</option>
            <option value="sparse">sparse</option>
        </param>
        <param name="fze" label="@string/script_label_erofs_compression_level" value="8" desc="@string/script_desc_ext4_only" />
        <param name="type" label="@string/script_label_erofs_compression_method" desc="@string/script_desc_ext4_only">
            <option value="lz4hc">lz4hc</option>
            <option value="lz4">lz4</option>
            <option value="lzma">lzma</option>
            <option value="deflate">deflate</option>
        </param>
    </action>

    <action>
        <title>@string/script_action_pack_super</title>
        <set>script/tool.sh packsuper</set>
        <param name="type" label="@string/script_label_pack_type">
            <option value="A">a_only</option>
            <option value="AB">ab</option>
            <option value="VAB">virtual_ab</option>
        </param>
        <param name="from" label="@string/script_label_pack_format">
            <option value="sparse">sparse</option>
            <option value="raw">raw</option>
        </param>
        <param name="super_size" required="true" value="12884901888" label="@string/script_label_super_total_size" desc="@string/script_desc_default_bytes" />
        <param name="super_group" required="true" value="main" label="@string/script_label_dynamic_partition_group" desc="@string/script_desc_suitable_size" />
        <param name="simg" title="@string/script_title_select_pack_img" options-sh="script/tool.sh img" desc="@string/script_desc_do_not_select_unsupported_image" required="true" multiple="true"/>
    </action>
</group>

<group title="@string/script_group_format_conversion">
    <action>
        <title>@string/script_action_img_conversion</title>
        <set>script/tool.sh gszh</set>
        <param name="del" label="@string/script_label_delete_source" type="switch" />
        <param name="gs" label="@string/script_label_conversion_format" desc="@string/script_desc_erofs_not_supported">
            <option value="dat">dat</option>
            <option value="br">br</option>
            <option value="sparse">sparse</option>
            <option value="raw">raw</option>
            <option value="zstd">zstd</option>
        </param>
        <param name="brlv" required="true" value="3" label="@string/script_label_br_compression_level" type="seekbar" min="0" max="9" desc="@string/script_desc_number_higher_slower"/>
        <param name="zstdle" required="true" value="3" label="@string/script_label_zstd_compression_level" type="seekbar" min="0" max="9" desc="@string/script_desc_number_higher_slower"/>
        <param name="IMG" title="@string/script_title_select_files_multi" options-sh="script/tool.sh img" desc="@string/script_desc_detect_project_files" required="true" multiple="true"/>
    </action>
</group>
